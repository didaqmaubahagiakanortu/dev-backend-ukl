// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String
  password  String
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt()
  passenger Passenger?
  admin     Admin?
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?     @unique
}

model Passenger {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt()
  user         User?         @relation(fields: [userId], references: [id])
  userId       Int?          @unique
  // tickets      Ticket[]
  // transactions Transaction[]
  transactions Transaction[]
}

model Train {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  carriages Carriage[]
  tickets   Ticket[]
}

model Carriage {
  id        Int      @id @default(autoincrement())
  code      String
  class     Class
  capacity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  train     Train?   @relation(fields: [trainId], references: [id])
  trainId   Int?
  tickets   Ticket[]
}

model Ticket {
  id           Int           @id @default(autoincrement())
  origin       String
  destination  String
  departure    DateTime
  arrival      DateTime
  price        Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  train        Train?        @relation(fields: [trainId], references: [id])
  trainId      Int?
  carriage     Carriage?     @relation(fields: [carriageId], references: [id])
  carriageId   Int?
  transactions Transaction[]
}

model Transaction {
  id           Int        @id @default(autoincrement())
  method       Method
  status       Status
  ticketAmount Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  passenger    Passenger? @relation(fields: [passengerId], references: [id])
  passengerId  Int?
  ticket       Ticket?    @relation(fields: [ticketId], references: [id])
  ticketId     Int?
}

enum Role {
  USER
  ADMIN
}

enum Class {
  EKONOMI
  BISNIS
  EKSEKUTIF
}

enum Method {
  CASH
  CASHLESS
}

enum Status {
  PENDING
  PAID
  CANCELLED
}
