generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  password  String
  email     String
  admin     Admin?
  passenger Passenger?
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?     @unique
  user      User?    @relation(fields: [userId], references: [id])
}

model Passenger {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       Int?          @unique
  user         User?         @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Train {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  carriages Carriage[]
  tickets   Ticket[]
}

model Carriage {
  id        Int      @id @default(autoincrement())
  code      String
  class     Class
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trainId   Int?
  train     Train?   @relation(fields: [trainId], references: [id])
  seats     Seat[]
  tickets   Ticket[]
}

model Seat {
  id            Int          @id @default(autoincrement())
  code          String
  taken         Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  carriageId    Int?
  transactionId Int?
  carriage      Carriage?    @relation(fields: [carriageId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
}

model Ticket {
  id           Int           @id @default(autoincrement())
  origin       String
  destination  String
  departure    DateTime
  arrival      DateTime
  price        Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  trainId      Int?
  carriageId   Int?
  carriage     Carriage?     @relation(fields: [carriageId], references: [id])
  train        Train?        @relation(fields: [trainId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id           Int        @id @default(autoincrement())
  method       Method     @default(UNPAID)
  status       Status     @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  passengerId  Int?
  ticketAmount Int
  ticketId     Int?
  seat         Seat[]
  passenger    Passenger? @relation(fields: [passengerId], references: [id])
  ticket       Ticket?    @relation(fields: [ticketId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Class {
  EKONOMI
  BISNIS
  EKSEKUTIF
}

enum Method {
  CASH
  CASHLESS
  UNPAID
}

enum Status {
  PENDING
  PAID
  CANCELLED
}
